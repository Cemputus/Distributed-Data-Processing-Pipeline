# Copy to .env and adjust. Docker Compose reads this automatically.

# Airflow (match container user if bind-mount permission errors on Linux; on Docker Desktop Windows often leave default)
AIRFLOW_UID=50000
AIRFLOW_GID=0

# Fernet key required for Airflow metadata encryption — generate a new one for anything beyond local dev
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=REPLACE_WITH_FERNET_KEY

# MinIO (S3-compatible) — change for anything beyond local dev
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
