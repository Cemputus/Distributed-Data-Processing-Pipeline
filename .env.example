# Copy to .env and adjust. Docker Compose reads this automatically.

# Airflow (match container user if bind-mount permission errors on Linux; on Docker Desktop Windows often leave default)
AIRFLOW_UID=50000
AIRFLOW_GID=0

# Fernet key for Airflow metadata encryption (generate a new one for production)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=iyLwftypiMBgb9yof6cFuflGvEfFGV7-lFfLLBfSDuw=

# Enable REST API Basic Auth (backend triggers DAGs with user/password). Without this, POST /api/v1/... can return "CSRF session token is missing".
# docker-compose.yml sets AIRFLOW__API__AUTH_BACKENDS for the Airflow image; set the same if you run Airflow outside Compose.
# AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session

# MinIO (S3-compatible) — change for anything beyond local dev
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# URL shown in the app to open MinIO Console (Docker Desktop: http://localhost:9001)
MINIO_CONSOLE_PUBLIC=http://localhost:9001

# Spark Standalone Master Web UI (ETL page + API). Compose defaults work inside Docker.
# Backend fetches cluster JSON from SPARK_MASTER_UI_INTERNAL_URL; browser links use SPARK_MASTER_UI_PUBLIC.
# SPARK_MASTER_UI_INTERNAL_URL=http://spark-master:8085
# SPARK_MASTER_UI_PUBLIC=http://localhost:8085

# -----------------------------------------------------------------------------
# BigQuery (secondary warehouse; optional)
# Service account JSON has "project_id" and must match BIGQUERY_PROJECT_ID (e.g. cloud-project-493415).
# Create the dataset once in BigQuery console in the same region as BIGQUERY_DATASET_LOCATION.
# IAM: grant the service account BigQuery Job User + BigQuery Data Editor (or Data Viewer + jobUser) on the dataset.
# -----------------------------------------------------------------------------
# Use either GOOGLE_APPLICATION_CREDENTIALS (standard) or BIGQUERY_CREDENTIALS_PATH (Docker template alias).
# Host dev (Windows): point at your checked-out key (do not commit — see .gitignore).
# GOOGLE_APPLICATION_CREDENTIALS=D:/Distributed Data Processing Pipeline/secrets/cloud-project-493415-1be4ba53f9c5.json
BIGQUERY_ENABLED=true
BIGQUERY_PROJECT_ID=cloud-project-493415
# Primary analytics / default dataset (matches in-app hints and samples)
BIGQUERY_DEFAULT_DATASET=cen_analytics
# Where uploads are loaded when BIGQUERY_AUTO_LOAD_ON_UPLOAD=true (often same as default)
BIGQUERY_INGEST_DATASET=cen_analytics
BIGQUERY_DATASET_LOCATION=US
# Copy your SA JSON into ./secrets/ — Compose mounts ./secrets to /secrets in the backend container.
# BIGQUERY_CREDENTIALS_PATH=/secrets/cloud-project-493415-1be4ba53f9c5.json
# Or standard name: cp your key to secrets/gcp-sa.json and set:
# BIGQUERY_CREDENTIALS_PATH=/secrets/gcp-sa.json
# -----------------------------------------------------------------------------

# When running the backend in Docker Compose, set the same variables in .env or rely on compose defaults.
BIGQUERY_AUTO_LOAD_ON_UPLOAD=false
# Table name on load = sanitized CSV basename (e.g. dim_accounts.csv → dim_accounts).


GOOGLE_APPLICATION_CREDENTIALS=d:/Distributed Data Processing Pipeline/secrets/cloud-project-493415-1be4ba53f9c5.json