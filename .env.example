# Copy to .env and adjust. Docker Compose reads this automatically.

# Airflow (match container user if bind-mount permission errors on Linux; on Docker Desktop Windows often leave default)
AIRFLOW_UID=50000
AIRFLOW_GID=0

# Fernet key for Airflow metadata encryption (generate a new one for production)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=iyLwftypiMBgb9yof6cFuflGvEfFGV7-lFfLLBfSDuw=

# MinIO (S3-compatible) — change for anything beyond local dev
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Google BigQuery (copy your service account JSON to secrets/gcp-sa.json for Docker backend mount)
BIGQUERY_PROJECT_ID=cloud-project-493415
# Optional: only if you use unqualified names in SQL; must be a dataset that exists in your project.
BIGQUERY_DEFAULT_DATASET=
# IAM (GCP Console → IAM): grant this service account at least:
#   roles/bigquery.dataViewer, roles/bigquery.jobUser, roles/bigquery.metadataViewer
# (or roles/bigquery.admin for local dev) so datasets/tables match the BigQuery console.
